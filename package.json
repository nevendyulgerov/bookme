{
  "name": "bookme",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run chakra-types && vite --port 5200",
    "build": "npm run chakra-types && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "extract": "formatjs extract",
    "intl:extract": "npm run extract -- 'src/**/*.ts*' --ignore='**/*.d.ts' --out-file src/locale/en.json --id-interpolation-pattern '[sha512:contenthash:base64:6]'",
    "chakra-types": "chakra typegen ./src/theme/theme.ts"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.28.1",
    "@emotion/react": "^11.14.0",
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.90.6",
    "date-fns": "^4.1.0",
    "lodash": "^4.17.21",
    "next-themes": "^0.4.6",
    "react": "^19.1.1",
    "react-datepicker": "^9.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.66.0",
    "react-icons": "^5.5.0",
    "react-intl": "^8.0.6",
    "react-redux": "^9.2.0",
    "react-router": "^7.9.5",
    "react-router-dom": "^7.9.5",
    "recharts": "^3.7.0",
    "redux-persist": "^6.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@chakra-ui/cli": "^3.30.0",
    "@eslint/js": "^9.36.0",
    "@formatjs/cli": "^6.8.6",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-plugin-formatjs": "^11.0.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
